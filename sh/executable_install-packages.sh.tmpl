{{ if (eq .chezmoi.osRelease.idLike "arch") }}

echo -n "➔ 正在同步官方源并检查系统软件包... "
# 丢弃标准输出，利用进程替换过滤掉 Stderr 中的 skipping 警告
sudo pacman -Syu --needed --noconfirm "${PACKAGES[@]}" >/dev/null 2> >(grep -v -E "is up to date|skipping" >&2)
echo "完成"

if command -v paru &> /dev/null; then
    echo -n "➔ 正在验证并构建 AUR 软件包... "
    # 重定向标准输出，并过滤 Stderr 里的编译无关警告
    paru -S --needed --noconfirm "${AURPACKAGES[@]}" >/dev/null 2> >(grep -v -E "is up to date|skipping|Validating|Retrieving" >&2)
    echo "完成"
else
    echo "⚠️ 错误: 未找到 paru 命令，无法自动安装 AUR 软件包。"
fi

{{ end }}
